# ---- Base de datos ----
# ⚠️ MULTI-TENANT: usa el rol `crm_app` (sin BYPASSRLS), NO el dueño/superusuario,
# o RLS se ignora y NO hay aislamiento entre clientes. Ver MULTI-TENANT.md.
DATABASE_URL="postgresql://crm_app:CAMBIAME@localhost:5432/ambarcrm?schema=public"

# ---- Auth.js / NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"

# ---- Multi-tenant (resolución de la org) ----
DEFAULT_ORG_SLUG="inicial"          # dev / dominio único; en prod resuelve por subdominio
# BASE_DOMAIN_FIRST_LABEL="www"     # primera etiqueta fija de tu dominio base (si aplica)

# ---- Meta Tech Provider (Embedded Signup / coexistencia) ----
# META_APP_ID=""                    # solo servidor (canje del code)
# META_APP_SECRET=""                # solo servidor
# NEXT_PUBLIC_META_APP_ID=""        # frontend: FB.init
# NEXT_PUBLIC_META_CONFIG_ID=""     # config_id del Embedded Signup (Tech Provider + coexistencia)

# ---- API para n8n (ingesta de webhooks de WhatsApp) ----
WA_API_KEY="clave-larga-para-que-n8n-llame-los-endpoints"

# ---- Evolution API (proveedor de WhatsApp actual) ----
EVOLUTION_API_URL="https://evolution.tudominio.com"
EVOLUTION_API_KEY="apikey-global-de-evolution"
EVOLUTION_INSTANCE="ambarcrm"

# ---- WhatsApp Cloud API (fase de migración a coexistencia Meta) ----
# CLOUD_API_TOKEN=""
# CLOUD_API_PHONE_NUMBER_ID=""
# CLOUD_API_VERIFY_TOKEN=""

# ---- Notificaciones push (opcional; genera el par con: npx web-push generate-vapid-keys) ----
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
