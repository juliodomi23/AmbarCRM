# Variables del docker-compose (raíz de AmbarCRM)

# ---- Postgres ----
# POSTGRES_* = rol dueño (solo migra/init). La app NO usa este rol.
POSTGRES_USER=ambarcrm
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE
POSTGRES_DB=ambarcrm
# Rol con el que corre la app (sometido a RLS). Usa solo letras/números (va en DATABASE_URL).
CRM_APP_PASSWORD=CAMBIA_ESTA_CLAVE_APP

# ---- App / Auth ----
NEXTAUTH_URL=https://crm.tudominio.com
NEXTAUTH_SECRET=genera_uno_con_openssl_rand_base64_32

# ---- API para n8n ----
WA_API_KEY=clave_larga_para_n8n

# ---- Evolution API ----
EVOLUTION_API_URL=https://evolution.tudominio.com
EVOLUTION_API_KEY=apikey_global_evolution
EVOLUTION_INSTANCE=ambarcrm

# ---- IA (sugerencias de respuesta en el chat) ----
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Notificaciones push (opcional; sin claves la app corre igual, solo sin push) ----
# Genera el par con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
